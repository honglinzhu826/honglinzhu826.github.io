---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/ui';

// Generate static paths for all supported languages
export function getStaticPaths() {
  const languages: Lang[] = ['zh', 'en'];
  return languages.map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Get thoughts for current language
const thoughts = await getCollection('thoughts', entry => {
  return entry.id.startsWith(`${lang}/`);
});

// Sort by date (newest first)
const sortedThoughts = thoughts.sort((a, b) =>
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat(lang === 'zh' ? 'zh-CN' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
}
---

<BaseLayout title={t('thoughts.title')} description={t('thoughts.description')}>
  <h1>{t('thoughts.title')}</h1>
  <p class="description">{t('thoughts.description')}</p>

  {sortedThoughts.length > 0 ? (
    <div class="post-list">
      {sortedThoughts.map(thought => {
        const slug = thought.id.replace(`${lang}/`, '').replace('.md', '');
        return (
          <article class="thought-item">
            <h3>
              <a href={`/${lang}/thoughts/${slug}/`}>
                {thought.data.mood && <span class="mood">{thought.data.mood} </span>}
                {thought.data.title}
              </a>
            </h3>
            <div class="post-meta">
              <time>{formatDate(thought.data.pubDate)}</time>
            </div>
          </article>
        );
      })}
    </div>
  ) : (
    <p class="empty">{t('no.thoughts')}</p>
  )}
</BaseLayout>

<style>
  .description {
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  .empty {
    text-align: center;
    padding: 3rem 0;
    color: var(--color-text-secondary);
  }
</style>
