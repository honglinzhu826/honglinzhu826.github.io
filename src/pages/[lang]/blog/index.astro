---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/ui';

// Generate static paths for all supported languages
export function getStaticPaths() {
  const languages: Lang[] = ['zh', 'en'];
  return languages.map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Get blog posts for current language
const posts = await getCollection('blog', entry => {
  return entry.id.startsWith(`${lang}/`) && !entry.data.draft;
});

// Sort by date (newest first)
const sortedPosts = posts.sort((a, b) =>
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

// Format date
function formatDate(date: Date): string {
  return new Intl.DateTimeFormat(lang === 'zh' ? 'zh-CN' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
}
---

<BaseLayout title={t('blog.title')} description={t('blog.description')}>
  <h1>{t('blog.title')}</h1>
  <p class="description">{t('blog.description')}</p>

  {sortedPosts.length > 0 ? (
    <div class="post-list">
      {sortedPosts.map(post => {
        const slug = post.id.replace(`${lang}/`, '').replace('.md', '');
        return (
          <article class="post-item">
            <h2>
              <a href={`/${lang}/blog/${slug}/`}>{post.data.title}</a>
            </h2>
            <div class="post-meta">
              <time>{formatDate(post.data.pubDate)}</time>
            </div>
            <p class="post-description">{post.data.description}</p>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </article>
        );
      })}
    </div>
  ) : (
    <p class="empty">{t('no.posts')}</p>
  )}
</BaseLayout>

<style>
  .description {
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  .empty {
    text-align: center;
    padding: 3rem 0;
    color: var(--color-text-secondary);
  }
</style>
